{
  "choices": [
    {
      "id": "capture-inbox",
      "name": "Capture to Inbox",
      "type": "Capture",
      "command": false,
      "format": {
        "enabled": true,
        "format": "---\ntitle: \"{{VALUE}}\"\ncaptured: {{DATE:YYYY-MM-DD}}\nsource: manual\nprocessed: false\nsuggested_destination: \"\"\ntags: [inbox]\n---\n\n# {{VALUE}}\n\n"
      },
      "captureTo": "04-Inbox/intake/{{DATE:YYYY-MM-DD}}-quick-capture.md",
      "createFileIfItDoesntExist": {
        "enabled": true,
        "createWithTemplate": false
      },
      "task": false,
      "prepend": false,
      "append": true
    },
    {
      "id": "add-action-item",
      "name": "Add Action Item to Next Up",
      "type": "Capture",
      "command": false,
      "format": {
        "enabled": true,
        "format": "| you | {{VALUE}} |  |  |\n"
      },
      "captureTo": "Todo.md",
      "createFileIfItDoesntExist": {
        "enabled": false
      },
      "task": false,
      "prepend": false,
      "append": true,
      "insertAfter": {
        "enabled": true,
        "after": "## Next Up"
      }
    },
    {
      "id": "quick-scratch",
      "name": "Quick Scratch Note",
      "type": "Capture",
      "command": false,
      "format": {
        "enabled": true,
        "format": "- {{VALUE}}\n"
      },
      "captureTo": "02-Weekly/{{DATE:YYYY-[W]ww}}.md",
      "createFileIfItDoesntExist": {
        "enabled": false
      },
      "task": false,
      "prepend": false,
      "append": true
    }
  ],
  "macros": [],
  "inputPrompt": "single-line",
  "templateFolderPath": "Templates"
}
